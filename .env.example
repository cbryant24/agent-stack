# ── Secrets below are 1Password references, resolved at runtime by `op run`. ───
# Run the stack via:  op run --env-file=.env -- <command>
#   e.g.  op run --env-file=.env -- uv run orchestrator chat
# Plain `uv run` passes the literal op:// string through unresolved and will fail.

# ── API Keys (required) ────────────────────────────────────────────────────────
# Anthropic Claude API key
PRODUCTION_AGENTS_ANTHROPIC_API_KEY=op://Personal/PRODUCTION_AGENTS_ANTHROPIC_API_KEY/credential
# optional — orchestrator-only key for separate Console cost tracking; falls back to PRODUCTION_AGENTS_ANTHROPIC_API_KEY if unset
ORCHESTRATOR_ANTHROPIC_API_KEY=op://Personal/ORCHESTRATOR_ANTHROPIC_API_KEY/credential
# Voyage AI — used for embeddings
VOYAGE_API_KEY=op://Personal/VOYAGE_API_KEY/credential
# Tavily — used for web search
TAVILY_API_KEY=op://Personal/TAVILY_API_KEY/credential
# ElevenLabs — text-to-speech (read-only: voices + usage in Phase 2 Step 1)
ELEVENLABS_API_KEY=op://Personal/ELEVENLABS_API_KEY/credential

# ── Infrastructure (defaults work with docker-compose up) ──────────────────────
QDRANT_URL=http://localhost:6333
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Data directories ───────────────────────────────────────────────────────────
AGENT_DATA_DIR=~/agent-data
AGENT_REPORTS_VAULT=~/obsidian/agent-reports

# ── YT Intelligence Pipeline ───────────────────────────────────────────────────
# LangSmith tracing key (required by yt-intelligence-pipeline)
LANGSMITH_API_KEY=op://Personal/LANGSMITH_API_KEY/credential
LANGSMITH_PROJECT=youtube-tutorial-pipeline
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
OBSIDIAN_OUTPUT_PATH=       # Absolute path to your Obsidian vault folder for human-mode notes
YOUTUBE_COOKIES_FILE=~/agent-data/youtube-cookies.txt   # yt-dlp cookies; optional, falls back to unauthenticated if absent
YOUTUBE_REMOTE_COMPONENTS=ejs:github   # yt-dlp EJS challenge solver; required for real formats. Empty disables remote fetch
